source 'https://rubygems.org'
gem 'jekyll'

group :jekyll_plugins do
  gem 'jekyll-katex'
  gem 'jekyll-multiple-languages-plugin'
  gem 'jekyll-twitter-plugin'
end

# Standard libraries removed from Ruby 3.4+ default gems
group :default do
  gem "base64"
  gem "bigdecimal"
  gem "csv"
  gem "logger"
end

gem "webrick", "~> 1.7"  # https://github.com/jekyll/jekyll/issues/8523
gem "liquid", "~> 4.0", ">= 4.0.4" # https://github.com/jekyll/jekyll/issues/9233#issuecomment-1379147523

